@namespace Talk.Client.Slides

<PlaygroundSlide Title="Tweak a parameter, live">
    <Preview>
        <div style="width:@(_size)px; height:@(_size)px; border-radius:14px;
                    background:var(--accent); display:flex; align-items:center;
                    justify-content:center; color:#0b0c10; font-weight:700;">
            @_size
        </div>
    </Preview>
    <Controls>
        <label>Size: <strong style="color:var(--accent)">@_size px</strong></label>
        <input type="range" min="40" max="220" step="1" @bind="_size" @bind:event="oninput" />
        <p style="opacity:.6; font-size:.9rem;">
            <code>@@bind</code> with <code>@@bind:event="oninput"</code> updates the preview as you drag.
        </p>
    </Controls>
</PlaygroundSlide>

@code {
    private int _size = 120;
}
