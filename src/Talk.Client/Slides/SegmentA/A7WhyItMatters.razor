@namespace Talk.Client.Slides

<SplitSlide Title="Why the render mode matters">
    <Left>
        <div class="rm-card">
            <div class="rm-head">
                <span class="rm-name">Interactive Server</span>
                <span class="rm-where">runs on the server</span>
            </div>
            <ul class="rm-traits">
                <li>Reaches the database, secrets, and server-only APIs directly</li>
                <li>"scoped" DI is per <strong>circuit</strong></li>
            </ul>
            <div class="rm-when">
                <span class="rm-when-label">reach for it when</span>
                you need server resources, a tiny download, or trusted logic — and the
                user count is bounded (each holds a live connection + server memory).
            </div>
        </div>
    </Left>
    <Right>
        <div class="rm-card">
            <div class="rm-head">
                <span class="rm-name">Interactive WebAssembly</span>
                <span class="rm-where">runs in the browser</span>
            </div>
            <ul class="rm-traits">
                <li>Every line ships to the client — no secrets; data over HTTP</li>
                <li>"scoped" DI is per <strong>app</strong></li>
            </ul>
            <div class="rm-when">
                <span class="rm-when-label">reach for it when</span>
                you have <strong>lots of clients</strong>, want offline / resilience, or rich
                client-side interactivity — with no per-user server load.
            </div>
        </div>
    </Right>
    <Footer>
        <p class="rm-foot"><strong>Auto runs the same component both ways</strong> — Server first,
            WebAssembly on the next visit. So write it as if it's client-side: assume no server
            access, embed no secrets, and reach data through services that work in either.</p>
    </Footer>
</SplitSlide>

<style>
    .rm-card {
        display: flex; flex-direction: column; gap: 1rem;
        padding: 1.5rem 1.6rem; border-radius: 14px;
        border: 1px solid color-mix(in srgb, var(--deck-border) 55%, var(--deck-fg) 22%);
        background: color-mix(in srgb, var(--deck-surface) 86%, var(--deck-fg) 9%);
        box-shadow: 0 16px 40px -28px rgba(0, 0, 0, 0.8);
    }
    .rm-head { display: flex; flex-direction: column; gap: 0.15rem; }
    .rm-name { font-size: 1.4rem; font-weight: 700; color: var(--accent); }
    .rm-where { font-size: 0.78rem; opacity: 0.55; text-transform: uppercase; letter-spacing: 0.1em; }
    .rm-traits {
        margin: 0; padding-left: 1.2rem; display: flex; flex-direction: column; gap: 0.5rem;
        font-size: 1.02rem; line-height: 1.45; opacity: 0.9;
    }
    .rm-traits strong { color: var(--accent); }
    .rm-when {
        margin-top: 0.3rem; padding-top: 0.9rem; border-top: 1px solid var(--deck-border);
        font-size: 0.98rem; line-height: 1.45; opacity: 0.85;
    }
    .rm-when-label {
        display: block; margin-bottom: 0.35rem;
        font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent);
    }
    .rm-when strong { color: var(--accent); }
    .rm-foot { margin: 0; }
    .rm-foot strong { color: var(--accent); font-weight: 600; }
</style>
