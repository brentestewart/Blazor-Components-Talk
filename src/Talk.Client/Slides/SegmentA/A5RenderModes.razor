@namespace Talk.Client.Slides

<Slide Title="Four render modes">
    <div class="modes">
        @foreach (var m in _modes)
        {
            <div class="mode-card @(m.IsDeck ? "deck" : null)">
                @if (m.IsDeck)
                {
                    <span class="mode-tag">this deck</span>
                }
                <div class="mode-name">@m.Name</div>
                <div class="mode-desc">@m.Desc</div>
            </div>
        }
    </div>
    <Caption Spaced>You pick one with the <code>@@rendermode</code> directive — on a component
        instance, in the component itself, or app-wide on <code>&lt;Routes&gt;</code>. Omit it and
        you get Static SSR.</Caption>
</Slide>

@code {
    private record Mode(string Name, string Desc, bool IsDeck = false);

    private static readonly Mode[] _modes =
    {
        new("Static SSR", "HTML rendered on the server, no interactivity"),
        new("Interactive Server", "UI runs on the server over a SignalR circuit"),
        new("Interactive WebAssembly", ".NET runs in the browser"),
        new("Interactive Auto", "Server first for a fast start, then WebAssembly once it loads", IsDeck: true),
    };
}
