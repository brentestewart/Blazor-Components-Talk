@namespace Talk.Client.Slides

<SplitSlide Title="Which mode is this slide?">
    <Left>
        <p>This deck uses <strong style="color:var(--accent)">Interactive Auto</strong>.</p>
        <p>First paint is static, prerendered HTML.</p>
        <p>Then it goes interactive <strong style="color:var(--accent)">on the server</strong> (SignalR) —
            while the WebAssembly runtime downloads and caches in the background.</p>
        <p>It won't switch mid-page. But your <strong style="color:var(--accent)">next</strong> visit
            runs entirely in the browser.</p>
    </Left>
    <Right>
        <LiveFrame>
            <div class="mode-live">
                <div class="ml-label">running as</div>
                <div class="ml-name">@RendererInfo.Name</div>
                <div class="ml-flag">interactive: @(RendererInfo.IsInteractive ? "true" : "false")</div>
            </div>
        </LiveFrame>
        <p class="ml-hint">↻ Reload (<kbd>r</kbd>) and watch it flip from
            <strong>Server</strong> to <strong>WebAssembly</strong>.</p>
    </Right>
</SplitSlide>
