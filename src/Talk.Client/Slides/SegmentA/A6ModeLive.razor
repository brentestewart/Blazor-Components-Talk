@namespace Talk.Client.Slides

<SplitSlide Title="Which mode is this slide?">
    <Left>
        <p>This deck uses <strong style="color:var(--accent)">Interactive Auto</strong>:</p>
        <p>server-rendered for a fast first paint, then WebAssembly once the runtime loads.</p>
        <p>Everything after those first moments runs in your browser.</p>
    </Left>
    <Right>
        <div class="mode-live">
            <div class="ml-label">running as</div>
            <div class="ml-name">@RendererInfo.Name</div>
            <div class="ml-flag">interactive: @RendererInfo.IsInteractive</div>
        </div>
    </Right>
</SplitSlide>

<style>
    .mode-live {
        border: 1px solid var(--deck-border);
        border-radius: 12px;
        padding: 2rem;
        text-align: center;
        background: var(--deck-surface-2);
    }
    .ml-label { text-transform: uppercase; letter-spacing: .1em; font-size: .8rem; opacity: .5; }
    .ml-name { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 700; color: var(--accent); margin: .5rem 0; }
    .ml-flag { opacity: .6; }
</style>
