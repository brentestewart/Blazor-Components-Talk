@namespace Talk.Client.Slides

@* A tiny interactive component embedded live on a DemoSlide. *@
<div style="display:flex; align-items:center; gap:1.5rem;">
    <button @onclick="() => _count--" style="font-size:1.4rem; padding:.2rem .9rem;">−</button>
    <span style="font-size:2.4rem; font-weight:600; color:var(--accent); min-width:3ch; text-align:center;">@_count</span>
    <button @onclick="() => _count++" style="font-size:1.4rem; padding:.2rem .9rem;">+</button>
</div>

@code {
    private int _count = 0;
}
