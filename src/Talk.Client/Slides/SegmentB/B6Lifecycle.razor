@namespace Talk.Client.Slides

@* Concept #8: lifecycle. The full ComponentBase hook sequence. Most come in a sync + async
   form; SetParametersAsync is async-only and ShouldRender is sync-only. A real OnAfterRender
   use (JS interop) comes later, in Segment D; ShouldRender returns in Segment E. *@
<Slide Title="The component lifecycle">
    <p class="lc-intro">Runs top to bottom. Most hooks have a sync and an <code>async</code> form.</p>
    <ul class="lifecycle">
        @foreach (var h in _hooks)
        {
            @if (h.DividerBefore)
            {
                <li class="lc-divider"><span>render</span></li>
            }
            <li class="lc-step@(h.Nested ? " lc-nested" : "")">
                <span class="lc-dot"></span>
                <div class="lc-body">
                    <code class="lc-name">@h.Name<span class="lc-async">@h.Twin</span></code>
                    <span class="lc-desc">@h.Desc</span>
                </div>
                <span class="lc-when">@h.When</span>
            </li>
        }
    </ul>
    <p class="lc-note"><span class="lc-note-tag">with prerendering</span>
        the hooks above <code>OnAfterRender</code> run <strong>twice</strong>: once for the static
        prerender, then again when the component goes interactive. <code>OnAfterRender</code> only
        fires once interactive, which is why it's the safe place for JS &amp; DOM work.</p>
</Slide>

@code {
    private record Hook(string Name, string Twin, string Desc, string When,
        bool Nested = false, bool DividerBefore = false);

    private static readonly Hook[] _hooks =
    {
        new("SetParametersAsync", "(async only)", "raw parameters arrive; the base assigns them, then runs:", "on set"),
        new("OnInitialized", "OnInitializedAsync", "the component is created; set up initial state", "once", Nested: true),
        new("OnParametersSet", "OnParametersSetAsync", "a parameter is set or changes; react to new inputs", "on change", Nested: true),
        new("ShouldRender", "(sync only)", "gate a re-render; return false to skip one", "before render", DividerBefore: true),
        new("OnAfterRender", "OnAfterRenderAsync", "it has rendered to the DOM; touch rendered elements", "after render"),
    };
}
