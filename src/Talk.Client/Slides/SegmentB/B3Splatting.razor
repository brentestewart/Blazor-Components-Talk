@namespace Talk.Client.Slides

@* Concept #5 — attribute splatting. The component collects undeclared attributes; a caller
   passes extras that land on the root element. *@
<Slide Title="Attribute splatting — the pass-through">
    <div class="splat">
        <CodeWindow FileName="Slide.razor" Language="razor" Code="@Declare" />
        <CodeWindow FileName="Page.razor" Language="razor" Code="@Use" />
        <Caption>
            <code>class</code> and <code>data-track</code> aren't declared parameters, so they're
            collected into <code>Extra</code> and splatted onto the root <code>&lt;div&gt;</code>.
            Without it, an undeclared attribute is a <strong>runtime error</strong> — a component
            rejects what it didn't expect.
        </Caption>
    </div>
</Slide>

@code {
    // The component collects the leftovers and splats them onto an element.
    private const string Declare = @"<div class=""slide"" @attributes=""Extra""> ... </div>

@code {
    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Extra { get; set; }
}";

    // A caller passes attributes the component never declared.
    private const string Use = @"<Slide Title=""Demo"" class=""wide"" data-track=""intro"" />";
}
