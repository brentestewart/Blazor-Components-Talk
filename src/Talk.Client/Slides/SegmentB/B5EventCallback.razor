@namespace Talk.Client.Slides

@* Concept #7 — EventCallback. Show the child that raises it and the parent that handles it,
   beside the live <Stepper> those files drive. (The deck's own nav skips EventCallback and
   routes clicks to a state container — Segment C.) *@
<SplitSlide Title="EventCallback" Subtitle="Talking back up" WideLeft="true">
    <Left>
        <div class="cb-code">
            <CodeWindow FileName="Stepper.razor" Language="razor" Code="@Child" />
            <CodeWindow FileName="Parent.razor" Language="razor" Code="@Parent" />
        </div>
    </Left>
    <Right>
        <LiveFrame>
            <div class="cb-body">
                <div class="cb-count">@_count</div>
                <Stepper OnStep="Step" />
            </div>
        </LiveFrame>
        <Caption Spaced>Why <code>EventCallback&lt;int&gt;</code> instead of a plain
            <code>Action&lt;int&gt;</code>? Invoking it re-renders the component that supplied the
            handler — the <strong>parent</strong> — so the count updates on its own. A raw delegate
            wouldn't; you'd call <code>StateHasChanged</code> yourself. It also awaits async handlers.</Caption>
    </Right>
</SplitSlide>

@code {
    private int _count;

    private void Step(int delta) => _count += delta;

    // The child: it owns no state — it just raises the callback.
    private const string Child = @"<button @onclick=""() => OnStep.InvokeAsync(-1)"">–</button>
<button @onclick=""() => OnStep.InvokeAsync(1)"">+</button>
@code {
    [Parameter] public EventCallback<int> OnStep { get; set; }
}";

    // The parent: it handles the callback and owns the count.
    private const string Parent = @"<p>@_count</p>
<Stepper OnStep=""Step"" />
@code {
    private int _count;
    void Step(int delta) => _count += delta;
}";
}
