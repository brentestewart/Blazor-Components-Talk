@namespace Talk.Client.Slides
@inherits SteppableSlide

@* Concept #21 — CSS isolation, following slide 9's .razor.css. Anchored to concrete code: a
   <Rating> child renders the <button>s; your component drops it inside a .box. The three
   build-steps then show scoped, the child boundary, and the ::deep escape hatch against THAT
   code, so every selector points at something on screen. *@
<Slide Title="Scoped CSS — and the ::deep escape hatch">
    <div class="iso">
        <div class="iso-left">
            <CodeWindow FileName="Stars.razor" Language="razor" Code="@Child" />
            <CodeWindow FileName="Review.razor" Language="razor" Code="@Parent" />
        </div>
        <div class="iso-right">
            <div class="iso-file">Review.razor.css <span class="hint">— write your styles here</span></div>
            @for (var i = 0; i < _rows.Length; i++)
            {
                var r = _rows[i];
                <div class="iso-row @(Step >= i ? "on" : "") @(r.Ok ? "ok" : "no")">
                    <div class="iso-line">
                        <code class="iso-code">@r.Write</code>
                        <span class="iso-arrow">→</span>
                        <code class="iso-code ships">@r.Pre<span class="tag">@r.Tag</span>@r.Post</code>
                    </div>
                    <div class="iso-reach"><span class="mark">@(r.Ok ? "✓" : "✗")</span> @r.Reach</div>
                </div>
            }
        </div>
    </div>
    <Caption>Styles for <code>Review.razor</code> go in a co-located <code>Review.razor.css</code>.
        The build tags every element <code>Review</code> renders with a unique <code>b-…</code> and
        rewrites each selector to match only those — so plain names can't leak or collide.
        <code>&lt;Stars&gt;</code>'s buttons carry <em>its</em> tag, not yours, so the scope stops
        there. <strong>::deep</strong> moves your tag onto <code>.box</code> to reach in.</Caption>
</Slide>

@code {
    public override int StepCount => 3;

    // The child component — it owns (renders) the buttons.
    private const string Child = @"<button>★</button>
<button>★</button>";

    // Your component — it drops <Stars> inside a .box it owns.
    private const string Parent = @"<div class=""box"">
    <h2>Rate it</h2>
    <Stars />
</div>";

    private record Row(string Write, string Pre, string Tag, string Post, bool Ok, string Reach);

    private static readonly Row[] _rows =
    {
        new("h2 { }", "h2", "[b-a1]", " { }", true,
            "your own <h2>"),
        new("button { }", "button", "[b-a1]", " { }", false,
            "nothing — the buttons live inside Stars"),
        new(".box ::deep button { }", ".box", "[b-a1]", " button { }", true,
            "Stars' buttons, reached"),
    };
}
