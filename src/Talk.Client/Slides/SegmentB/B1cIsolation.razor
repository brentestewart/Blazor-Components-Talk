@namespace Talk.Client.Slides
@inherits SteppableSlide

@* Concept #21: CSS isolation. Step 1: the source, the two components and the scoped stylesheet.
   Step 2: drop Stars (it's served its purpose) and show Review's rendered DOM beside the generated
   CSS, so the b-a1 rewrite, and why the child's buttons dodge it, is visible. *@
<Slide Title="CSS isolation" Subtitle="…and the ::deep escape hatch">
    <div class="iso-frame">
    <div class="iso">
        <div class="iso-left">
            @if (Step == 0)
            {
                <CodeWindow FileName="Stars.razor" Language="razor" Code="@Child" />
                <CodeWindow FileName="Review.razor" Language="razor" Code="@Parent" />
            }
            else
            {
                <CodeWindow FileName="Review.razor — rendered" Language="razor" Code="@ParentRendered" />
            }
        </div>
        <div class="iso-right">
            @if (Step == 0)
            {
                <CodeWindow FileName="Review.razor.css" Language="css" Code="@Styles" />
            }
            else
            {
                <CodeWindow FileName="Review.razor.css — generated" Language="css" Code="@StylesGen" />
            }
        </div>
    </div>
        @if (Step == 0)
        {
            <Caption>The build tags every element <code>Review</code> renders with a unique
                <code>b-…</code> and rewrites each selector to match only those. So which of these
                three actually hit? <span class="tease">Advance to see what the build generates. →</span></Caption>
        }
        else
        {
            <Caption><code>Review</code> has a stylesheet, so its <code>.box</code> and <code>&lt;h2&gt;</code>
                get <code>b-a1</code>, but the buttons came from <code>&lt;Stars&gt;</code>, so they don't.
                <code>button[b-a1]</code> matches none of them; <strong>::deep</strong> moves the tag onto
                <code>.box</code>, so <code>.box[b-a1] button</code> reaches them regardless.</Caption>
        }
    </div>
</Slide>

@code {
    public override int StepCount => 2;

    // The child component: it renders the buttons.
    private const string Child = @"<button>★</button>
<button>★</button>";

    // Your component: it drops <Stars> inside a .box it owns.
    private const string Parent = @"<div class=""box"">
    <h2>Rate it</h2>
    <Stars />
</div>";

    // What Review actually renders: its own elements carry b-a1; the buttons (from Stars) don't.
    private const string ParentRendered = @"<div class=""box"" b-a1>
    <h2 b-a1>Rate it</h2>
    <button>★</button>
    <button>★</button>
</div>";

    // The scoped stylesheet you write.
    private const string Styles = @"/* ✓ your own <h2> */
h2 { color: indigo; }

/* ✗ nothing, the buttons live in <Stars> */
button { color: gold; }

/* ✓ reaches into <Stars> */
.box ::deep button { color: gold; }";

    // What the build generates: your tag appended to each selector.
    private const string StylesGen = @"h2[b-a1]           { color: indigo; }  /* ✓ */
button[b-a1]       { color: gold; }    /* ✗ the buttons have no b-a1 */
.box[b-a1] button  { color: gold; }    /* ✓ any button under .box */";
}
