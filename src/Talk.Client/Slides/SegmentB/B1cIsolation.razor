@namespace Talk.Client.Slides
@inherits SteppableSlide

@* Concept #21 — CSS isolation, following slide 9's .razor.css. Anchored to concrete code: a
   <Rating> child renders the <button>s; your component drops it inside a .box. The three
   build-steps then show scoped, the child boundary, and the ::deep escape hatch against THAT
   code, so every selector points at something on screen. *@
<Slide Title="Scoped CSS — and the ::deep escape hatch">
    <div class="iso">
        <div class="iso-left">
            <CodeWindow FileName="Rating.razor" Language="razor" Code="@Child" />
            <CodeWindow FileName="Ratings.razor" Language="razor" Code="@Parent" />
        </div>
        <div class="iso-right">
            @for (var i = 0; i < _rows.Length; i++)
            {
                var r = _rows[i];
                <div class="iso-row @(Step >= i ? "on" : "") @(r.Ok ? "ok" : "no")">
                    <div class="iso-line">
                        <span class="iso-stage">@r.Stage</span>
                        <code class="iso-code">@r.Write</code>
                        <span class="iso-arrow">→</span>
                        <code class="iso-code ships">@r.Pre<span class="tag">@r.Tag</span>@r.Post</code>
                    </div>
                    <div class="iso-reach"><span class="mark">@(r.Ok ? "✓" : "✗")</span> @r.Reach</div>
                </div>
            }
        </div>
    </div>
    <Caption>The build tags every element <em>your</em> component renders with a unique
        <code>b-…</code> and rewrites each selector to match only those — so plain names can't leak
        or collide. <code>&lt;Rating&gt;</code>'s buttons carry <em>its</em> tag, not yours, so the
        scope stops there. <strong>::deep</strong> moves your tag onto <code>.box</code>, freeing the
        rest of the selector to reach in.</Caption>
</Slide>

@code {
    public override int StepCount => 3;

    // The child component — it owns (renders) the buttons.
    private const string Child = @"<button>★</button>
<button>★</button>";

    // Your component — it drops <Rating> inside a .box it owns.
    private const string Parent = @"<div class=""box"">
    <h2>Rate it</h2>
    <Rating />
</div>";

    private record Row(string Stage, string Write, string Pre, string Tag, string Post, bool Ok, string Reach);

    private static readonly Row[] _rows =
    {
        new("scoped", "h2 { }", "h2", "[b-a1]", " { }", true,
            "your own <h2>"),
        new("boundary", "button { }", "button", "[b-a1]", " { }", false,
            "nothing — the buttons live inside Rating"),
        new("::deep", ".box ::deep button { }", ".box", "[b-a1]", " button { }", true,
            "Rating's buttons, reached"),
    };
}
