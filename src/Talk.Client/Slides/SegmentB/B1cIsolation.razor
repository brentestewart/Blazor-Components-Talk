@namespace Talk.Client.Slides
@inherits SteppableSlide

@* Concept #21 — CSS isolation, following slide 9's .razor.css. Left: the two components (Stars
   renders the buttons; Review drops it in a .box). Right: Review.razor.css itself — three
   selectors annotated with whether they hit. Build-steps spotlight one selector at a time. *@
<Slide Title="Scoped CSS — and the ::deep escape hatch">
    <div class="iso">
        <div class="iso-left">
            <CodeWindow FileName="Stars.razor" Language="razor" Code="@Child" />
            <CodeWindow FileName="Review.razor" Language="razor" Code="@Parent" />
        </div>
        <div class="iso-right">
            <CodeWindow FileName="Review.razor.css" Language="css" Code="@Styles" Focus="_focus" Step="Step" />
        </div>
    </div>
    <Caption>Styles for <code>Review.razor</code> live in a co-located <code>Review.razor.css</code>.
        The build tags every element <code>Review</code> renders with a unique <code>b-…</code> and
        rewrites each selector to match only those — so <code>button</code> never reaches
        <code>&lt;Stars&gt;</code>'s markup. <strong>::deep</strong>, anchored to your own
        <code>.box</code>, is the one way through.</Caption>
</Slide>

@code {
    public override int StepCount => 3;

    // Spotlight one more selector per step (1-based, inclusive; cumulative so earlier ones stay lit).
    private static readonly (int From, int To)?[] _focus = { (1, 2), (1, 5), (1, 8) };

    // The child component — it renders the buttons.
    private const string Child = @"<button>★</button>
<button>★</button>";

    // Your component — it drops <Stars> inside a .box it owns.
    private const string Parent = @"<div class=""box"">
    <h2>Rate it</h2>
    <Stars />
</div>";

    // The scoped stylesheet — the same three selectors we've been discussing, and whether they hit.
    private const string Styles = @"/* ✓ your own <h2> */
h2 { color: indigo; }

/* ✗ nothing — the buttons live in <Stars> */
button { color: gold; }

/* ✓ reaches into <Stars> */
.box ::deep button { color: gold; }";
}
