@namespace Talk.Client.Slides

@* Concept #21 — CSS isolation, following slide 9's .razor.css. Left: the two components (Stars
   renders the buttons; Review drops it in a .box). Right: Review.razor.css itself — three
   selectors annotated with whether they hit. *@
<Slide Title="Scoped CSS — and the ::deep escape hatch">
    <div class="iso">
        <div class="iso-left">
            <CodeWindow FileName="Stars.razor" Language="razor" Code="@Child" />
            <CodeWindow FileName="Review.razor" Language="razor" Code="@Parent" />
        </div>
        <div class="iso-right">
            <CodeWindow FileName="Review.razor.css" Language="css" Code="@Styles" />
        </div>
    </div>
    <Caption>The build tags every element <code>Review</code> renders with a unique
        <code>b-…</code> and rewrites each selector to match only those — so <code>button</code>
        never reaches <code>&lt;Stars&gt;</code>'s markup. <strong>::deep</strong>, anchored to your
        own <code>.box</code>, is the one way through.</Caption>
</Slide>

@code {
    // The child component — it renders the buttons.
    private const string Child = @"<button>★</button>
<button>★</button>";

    // Your component — it drops <Stars> inside a .box it owns.
    private const string Parent = @"<div class=""box"">
    <h2>Rate it</h2>
    <Stars />
</div>";

    // The scoped stylesheet — the same three selectors we've been discussing, and whether they hit.
    private const string Styles = @"/* ✓ your own <h2> */
h2 { color: indigo; }

/* ✗ nothing — the buttons live in <Stars> */
button { color: gold; }

/* ✓ reaches into <Stars> */
.box ::deep button { color: gold; }";
}
