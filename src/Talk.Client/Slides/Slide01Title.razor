@namespace Talk.Client.Slides

<Slide Number="1">
    <p class="kicker">A Blazor Web App presenting itself</p>
    <h1 class="big">Unleashing the Power of<br />Blazor Components</h1>
    <p class="sub">Every slide you see is a Blazor component.
        Use &larr; / &rarr; to navigate, <kbd>t</kbd> for theme, <kbd>f</kbd> for fullscreen.</p>
</Slide>

<style>
    .kicker { color: var(--accent); text-transform: uppercase; letter-spacing: .15em; font-size: .9rem; margin: 0 0 1rem; }
    .big { font-size: clamp(2.2rem, 6vw, 4.2rem); font-weight: 700; line-height: 1.05; margin: 0 0 1.5rem; }
    .sub { opacity: .75; }
    kbd { background:#20232b; border:1px solid #333; border-radius:4px; padding:.05em .4em; font-size:.85em; }
</style>
