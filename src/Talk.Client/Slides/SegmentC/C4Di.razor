@namespace Talk.Client.Slides

@* Concept #12: dependency injection. Register a service once; inject it anywhere with
   @inject. Placed here because the state container (next slide) is a DI service. Real detail:
   an InteractiveAuto app registers it in BOTH Program.cs files, since Server and WebAssembly each
   have their own container. *@
<Slide Title="Dependency injection" Subtitle="Register once, inject anywhere">
    <div class="di-stack">
        <CodeWindow FileName="Program.cs" Language="csharp" Code="@Register" />
        <CodeWindow FileName="Deck.razor" Language="razor" Code="@Inject" />
        <Caption>This deck is <strong>InteractiveAuto</strong>, so a component might run on
            the Server circuit or in the WebAssembly runtime. Each has its own DI container, so
            <code>DeckState</code> is registered in <em>both</em> <code>Program.cs</code> files.</Caption>
    </div>
</Slide>

@code {
    private const string Register = @"// same line lives in Talk/Program.cs
// and Talk.Client/Program.cs
builder.Services.AddScoped<DeckState>();";

    private const string Inject = @"@inject DeckState State

@* available anywhere below *@
<span>@(State.Index + 1)</span>";
}
