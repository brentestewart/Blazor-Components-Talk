@namespace Talk.Client.Slides

@* Concept #11: cascading parameters. One provider high in the tree; every descendant that
   asks can read it, no matter how deep, without threading it through each layer. The real
   deck wraps the whole stage in <CascadingValue Value="State.Theme">. *@
<SplitSlide Title="Cascading parameters" Subtitle="Push to all descendants">
    <Left>
        <CodeWindow FileName="Deck.razor" Language="razor" Code="@Provider" />
    </Left>
    <Right>
        <CodeWindow FileName="AnySlide.razor" Language="razor" Code="@Consumer" />
    </Right>
    <Footer>
        <Caption>The deck cascades the <code>DeckTheme</code> once at the top. A descendant grabs it
            with <code>[CascadingParameter]</code>, matched by <strong>type</strong>, not by name, so the
            property can be called anything. Nothing is threaded through the parents in between.</Caption>
    </Footer>
</SplitSlide>

@code {
    // Real provider: the stage is wrapped in this.
    private const string Provider = @"<CascadingValue Value=""State.Theme"">
    <div class=""stage"">
        @* slides render here *@
    </div>
</CascadingValue>";

    // A descendant opts in by type (no Name), so the property name is arbitrary, here 'Current'.
    private const string Consumer = @"<h2 style=""color: @Current.Accent"">Deep slide</h2>

@code {
    // no Name, so it's matched by type
    [CascadingParameter]
    DeckTheme Current { get; set; }
}";
}
