@namespace Talk.Client.Slides

@* Concept #14 — the threading gotcha, placed right where it bites. When a re-render is
   triggered off the renderer's sync context — a timer, a background thread — you must marshal
   with InvokeAsync(StateHasChanged). The real deck hits this in its transition timer: after
   `await Task.Delay(650)` clears the outgoing slide layer, the continuation is off-thread. *@
<SplitSlide Title="StateHasChanged off-thread — use InvokeAsync" WideLeft="true">
    <Left>
        <CodeWindow FileName="Deck.razor" Language="csharp" Code="@Source" />
    </Left>
    <Right>
        <div class="th-side">
            <div class="th-rule th-bad">
                <span class="th-mark">✗</span>
                <div><code>StateHasChanged()</code><span>from a timer / background thread<br />→ <em>“not associated with the Dispatcher”</em></span></div>
            </div>
            <div class="th-rule th-good">
                <span class="th-mark">✓</span>
                <div><code>await InvokeAsync(StateHasChanged)</code><span>marshals back onto the renderer's thread</span></div>
            </div>
            <p class="th-when">Event handlers and lifecycle methods already run on that thread —
                you only need <code>InvokeAsync</code> when <em>you</em> leave it: after a
                <code>Task.Delay</code>, a <code>System.Timers.Timer</code>, or a service event
                raised off-thread.</p>
        </div>
    </Right>
</SplitSlide>

@code {
    // The transition timer: after the delay, we're on a thread-pool thread, not the renderer's.
    private const string Source = @"// clear the outgoing slide layer
await Task.Delay(TransitionMs);
_outgoing = null;

// continuation is off-thread now —
// marshal back before touching UI
await InvokeAsync(StateHasChanged);";
}

