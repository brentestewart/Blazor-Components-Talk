@namespace Talk.Client.Slides

<Slide Title="Render modes, live" Number="2">
    <p>This very slide is currently running as:</p>
    <p class="mode">@RendererInfo.Name
        <span class="flag">interactive: @RendererInfo.IsInteractive</span>
    </p>
    <p class="hint">Static SSR &rarr; Interactive Server &rarr; WebAssembly.
        The deck demonstrates the concept it's teaching.</p>
</Slide>

<style>
    .mode { font-size: clamp(1.6rem, 4vw, 2.6rem); font-weight: 600; color: var(--accent); margin: .5rem 0 1.5rem; }
    .flag { font-size: 1rem; opacity: .6; margin-left: 1rem; font-weight: 400; }
    .hint { opacity: .7; }
</style>
