@namespace Talk.Client.Slides

@* Concept #16 — generic components. @typeparam makes a component type-parameterized; the
   compiler infers the type from the data you pass. This dissects the deck's real BulletList<T>
   — the same component A4/A5/A7 use — rendered live on the right. *@
<SplitSlide Title="Generic components" WideLeft="true">
    <Left>
        <div class="stack">
            <CodeWindow FileName="BulletList.razor" Language="razor" Code="@Component" />
            <CodeWindow FileName="Page.razor" Language="razor" Code="@Caller" />
        </div>
    </Left>
    <Right>
        <LiveFrame Label="live — this is the component">
            <BulletList Items="_people">
                <ItemTemplate Context="p">@p.Name — @p.Role</ItemTemplate>
            </BulletList>
        </LiveFrame>
    </Right>
    <Footer>
        <Caption><code>TItem</code> is inferred as <code>Person</code> from
            <code>Items</code> — no cast, fully typed inside <code>&lt;ItemTemplate&gt;</code>.</Caption>
    </Footer>
</SplitSlide>

@code {
    private record Person(string Name, string Role);

    private readonly IEnumerable<Person> _people = new Person[]
    {
        new("Ada", "Engineer"),
        new("Grace", "Admiral"),
        new("Alan", "Theorist"),
    };

    private const string Component = @"@typeparam TItem

<ul>
    @foreach (var item in Items)
    {
        <li @key=""item"">@ItemTemplate(item)</li>
    }
</ul>

@code {
    [Parameter] public IEnumerable<TItem> Items { get; set; }
    [Parameter] public RenderFragment<TItem> ItemTemplate { get; set; }
}";

    private const string Caller = @"<BulletList Items=""_people"">
    <ItemTemplate Context=""p"">@p.Name — @p.Role</ItemTemplate>
</BulletList>";
}
