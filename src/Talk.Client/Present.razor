@page "/"
@page "/slide/{Number:int}"
@layout FullScreenLayout

<PageTitle>BlazorDeck</PageTitle>

<Deck Slides="Slides" InitialSlide="Number" InitialTheme="@ThemeParam"
      InitialTransition="@TransitionParam" DefaultTransition="SlideTransition.Fade" />

@code {
    // Slide is a route parameter (1-based); null on the bare "/" route (= slide 1).
    [Parameter] public int? Number { get; set; }

    // Theme + transition are view-state, so they stay in the query string.
    [SupplyParameterFromQuery(Name = "theme")]
    public string? ThemeParam { get; set; }

    [SupplyParameterFromQuery(Name = "transition")]
    public string? TransitionParam { get; set; }

    // The ordered table of contents. Each entry is a slide component + its overview title.
    private static readonly SlideInfo[] Slides =
    {
        // Segment A · Set the stage
        // All slides inherit the deck default transition (change it in settings — 's').
        new(typeof(A1Title), "Title") { Tag = "Title" },
        new(typeof(A2Reveal), "It's all components") { Tag = "Reveal" },
        new(typeof(A3Hello), "Hello") { Tag = "Hello" },
        new(typeof(A4Agenda), "What we'll cover") { Tag = "Agenda" },
        new(typeof(A5RenderModes), "Four render modes") { Tag = "RenderModes" },
        new(typeof(A6ModeLive), "Which mode is this slide?") { Tag = "RenderMode" },
        new(typeof(A7WhyItMatters), "Why render mode matters") { Tag = "WhyItMatters" },

        // Segment B · Fundamentals — each slide dissects a real deck component.
        new(typeof(B1Anatomy), "Anatomy — one file") { Tag = "ComponentAnatomy" },
        new(typeof(B1bAnatomyFiles), "Anatomy — separate files") { Tag = "ComponentFiles" },
        new(typeof(B1cIsolation), "CSS isolation") { Tag = "CssIsolation" },
        new(typeof(B2Parameters), "Parameters") { Tag = "Parameters" },
        new(typeof(B3Splatting), "Attribute splatting") { Tag = "AttributeSplatting" },
        new(typeof(B4Binding), "Data binding") { Tag = "DataBinding" },
        new(typeof(B5EventCallback), "EventCallback") { Tag = "EventCallback" },
        new(typeof(B6Lifecycle), "Lifecycle methods") { Tag = "Lifecycle" },

        // Segment C · Communication & DI — dissecting the deck's own state container.
        new(typeof(C1CommunicationMap), "How components talk") { Tag = "Communication" },
        new(typeof(C2Ref), "@ref — grab a handle") { Tag = "Ref" },
        new(typeof(C3Cascading), "Cascading parameters"),
        new(typeof(C4Di), "Dependency injection"),
        new(typeof(C5StateContainer), "State container (DeckState)"),
        new(typeof(C6StateHasChanged), "StateHasChanged"),
        new(typeof(C7Threading), "InvokeAsync threading"),

        // Segment D · Advanced composition
        new(typeof(D1Templated), "Templated components"),
        new(typeof(D2Generic), "Generic components"),
        new(typeof(D3DynamicComponent), "DynamicComponent"),
        new(typeof(D4JsInterop), "JavaScript interop"),
    };
}
