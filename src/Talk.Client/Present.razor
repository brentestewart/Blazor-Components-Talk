@page "/"
@rendermode InteractiveAuto
@layout FullScreenLayout

<PageTitle>BlazorDeck</PageTitle>

<Deck Slides="Slides" />

@code {
    // The ordered table of contents. Each entry is a slide component + its overview title.
    private static readonly SlideInfo[] Slides =
    {
        // Segment A · Set the stage
        new(typeof(A1Title), "Title"),
        new(typeof(A2Reveal), "It's all components"),
        new(typeof(A3Hello), "Hello"),
        new(typeof(A4Agenda), "What we'll cover"),
        new(typeof(A5RenderModes), "Four render modes"),
        new(typeof(A6ModeLive), "Which mode is this slide?"),
        new(typeof(A7WhyItMatters), "Why render mode matters"),
    };
}
