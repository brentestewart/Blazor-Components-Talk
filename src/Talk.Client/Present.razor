@page "/"
@rendermode InteractiveAuto
@layout FullScreenLayout

<PageTitle>BlazorDeck</PageTitle>

<Deck Slides="Slides" InitialSlide="SlideParam" DefaultTransition="SlideTransition.Fade" />

@code {
    [SupplyParameterFromQuery(Name = "slide")]
    public int? SlideParam { get; set; }

    // The ordered table of contents. Each entry is a slide component + its overview title.
    private static readonly SlideInfo[] Slides =
    {
        // Segment A · Set the stage
        // Most slides inherit the deck default (Fade); a few set their own transition.
        new(typeof(A1Title), "Title", SlideTransition.Fade),
        new(typeof(A2Reveal), "It's all components"),
        new(typeof(A3Hello), "Hello"),
        new(typeof(A4Agenda), "What we'll cover", SlideTransition.Slide),
        new(typeof(A5RenderModes), "Four render modes", SlideTransition.Slide),
        new(typeof(A6ModeLive), "Which mode is this slide?", SlideTransition.Scale),
        new(typeof(A7WhyItMatters), "Why render mode matters", SlideTransition.SlideVertical),
    };
}
