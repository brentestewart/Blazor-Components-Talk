@page "/not-found"
@layout FullScreenLayout

@* Standalone 404. It renders outside the Deck (and its MudThemeProvider), so it can't read the
   deck's theme variables — it carries its own minimal styling in NotFound.razor.css. *@
<div class="notfound">
    <h1>404</h1>
    <p>That slide doesn't exist.</p>
    <a href="/">← Back to the deck</a>
</div>
