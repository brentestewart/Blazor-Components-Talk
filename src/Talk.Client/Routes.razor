@* Interactive router. Lives in the .Client project so it runs in the WebAssembly/interactive
   runtime — that keeps slide navigation client-side (no server round-trip, no remount), which
   is what lets the Deck's transitions survive a move. AppAssembly is this client assembly,
   where the routable pages (Present) live. *@
<Router AppAssembly="typeof(Program).Assembly" NotFoundPage="typeof(Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
