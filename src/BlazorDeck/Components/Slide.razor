@namespace BlazorDeck.Components

@* Base slide layout — the frame around every slide. Single-file component: markup plus an
   inline @code block. Shows: component structure (#3), parameters (#4),
   attribute splatting (#5), CSS isolation (#21, in Slide.razor.css). *@

<div class="slide" @attributes="Extra">
    @if (!string.IsNullOrWhiteSpace(Title))
    {
        <h1 class="slide-title">@Title</h1>
    }
    <div class="slide-body">
        @ChildContent
    </div>
    @if (Number is int n)
    {
        <div class="slide-badge">@n</div>
    }
</div>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public int? Number { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Extra { get; set; }
}
