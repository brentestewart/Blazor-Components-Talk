@namespace BlazorDeck.Components

@* Base slide layout — the frame around every slide. Single-file component: markup plus an
   inline @code block. Shows: component structure (#3), parameters (#4),
   attribute splatting (#5), CSS isolation (#21, in Slide.razor.css). *@

<div class="slide" @attributes="Extra">
    @if (!string.IsNullOrWhiteSpace(Title))
    {
        <div class="slide-head">
            <h1 class="slide-title">@Title</h1>
            @if (!string.IsNullOrWhiteSpace(Subtitle))
            {
                <p class="slide-subtitle">@Subtitle</p>
            }
        </div>
    }
    <div class="slide-body">
        @ChildContent
    </div>
    @if (Number is int n)
    {
        <div class="slide-badge">@n</div>
    }
</div>

@code {
    [Parameter] public string? Title { get; set; }

    /// <summary>Optional second line under the title — use it instead of an em-dash clause.</summary>
    [Parameter] public string? Subtitle { get; set; }

    [Parameter] public int? Number { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Extra { get; set; }
}
