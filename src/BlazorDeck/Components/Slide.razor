@namespace BlazorDeck.Components

@* Base slide layout. Shows: component structure (#3), parameters (#4),
   attribute splatting (#5), cascading parameters (#11), CSS isolation (#21). *@

<div class="slide" style="--accent:@Theme.Accent" @attributes="Extra">
    @if (!string.IsNullOrWhiteSpace(Title))
    {
        <h1 class="slide-title">@Title</h1>
    }
    <div class="slide-body">
        @ChildContent
    </div>
    @if (Number is int n)
    {
        <div class="slide-badge">@n</div>
    }
</div>

@code {
    [CascadingParameter] public DeckTheme Theme { get; set; } = DeckTheme.Indigo;

    [Parameter] public string? Title { get; set; }
    [Parameter] public int? Number { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? Extra { get; set; }
}
