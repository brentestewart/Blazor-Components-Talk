@namespace BlazorDeck.Components

@* A slide that showcases a single code file. The code pane — highlighting, JS interop,
   and lifecycle — lives in the reusable CodeWindow. Shows: CSS isolation (#21),
   cascading theme (#11). *@
<div class="code-slide">
    @if (!string.IsNullOrWhiteSpace(Title))
    {
        <h1 class="cs-title">@Title</h1>
    }
    <CodeWindow Code="@Code" Language="@Language" FileName="@FileName" />
</div>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public string Code { get; set; } = string.Empty;
    [Parameter] public string Language { get; set; } = "csharp";
    [Parameter] public string? FileName { get; set; }
}
