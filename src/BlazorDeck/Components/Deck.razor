@namespace BlazorDeck.Components
@inject DeckState State
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IAsyncDisposable

@* The deck root. Shows: DynamicComponent as the rendering engine (#17),
   state container subscription (#13), cascading theme (#11),
   JS interop for keyboard + fullscreen (#18), virtualized overview (#20). *@

@{
    var t = State.Theme;
}
<MudThemeProvider Theme="@t.Mud" IsDarkMode="t.IsDark" />
<CascadingValue Value="State.Theme">
    @* dark/light gates the syntax palette; all colour values live in Deck.razor.css. *@
    <div class="deck @(t.IsDark ? "dark" : "light")">
        <div class="deck-aurora" aria-hidden="true">
            <span class="blob b1"></span>
            <span class="blob b2"></span>
        </div>
        <div class="deck-grid" aria-hidden="true"></div>
        <div class="deck-index" aria-hidden="true">@((State.Index + 1).ToString("D2"))</div>
        <div class="deck-tag" aria-hidden="true"><span class="br">&lt;</span>@ComponentName<span class="br"> /&gt;</span></div>
        <div class="deck-progress" style="width:@ProgressPercent%"></div>
        <div class="stage">
            @if (_outgoing is int outIdx)
            {
                <div class="slide-anim slide-layer @OutgoingClass @DirectionClass" @key="@($"out-{outIdx}")">
                    @* Freeze the exiting slide at the step it was on, so it doesn't snap back.
                       Guard it too: if the exiting slide throws on render, swallow it (empty
                       ErrorContent) — it's animating out and about to be discarded, so there's
                       nothing to recover. Without this, a slide that throws on render would still
                       crash the deck as you navigate away from it. *@
                    <ErrorBoundary>
                        <ChildContent>
                            <CascadingValue Name="Step" Value="_outgoingStep" IsFixed="true">
                                <DynamicComponent Type="Slides[outIdx].Type" />
                            </CascadingValue>
                        </ChildContent>
                        <ErrorContent></ErrorContent>
                    </ErrorBoundary>
                </div>
            }
            <div class="slide-anim slide-layer @TransitionClass @DirectionClass" @key="@($"in-{State.Index}")">
                @if (Slides.Count > 0)
                {
                    @* The slide host, wrapped so a throwing slide degrades to a fallback instead of
                       killing the circuit. The keyed div above gives a fresh boundary per slide, so
                       navigating away recovers automatically; Recover() re-attempts the same slide. *@
                    <ErrorBoundary @ref="_boundary">
                        <ChildContent>
                            <CascadingValue Name="Step" Value="State.Step">
                                <DynamicComponent @ref="_slide" Type="Slides[State.Index].Type" />
                            </CascadingValue>
                        </ChildContent>
                        <ErrorContent Context="ex">
                            <SlideErrorFallback Error="ex" OnRecover="RecoverSlide" />
                        </ErrorContent>
                    </ErrorBoundary>
                }
            </div>
        </div>

        @if (State.ShowOverview)
        {
            <div class="overview">
                <div class="ov-head">Overview — click to jump (Esc to close)</div>
                <div class="ov-grid">
                    @foreach (var entry in _indexed)
                    {
                        @* Each card renders the real slide, live, at full size inside a viewport-sized
                           stage that CSS scales down (--ov-k, set from the window by deck.js). It's the
                           deck rendering all of itself — "it's all components," taken literally. The
                           stage is pointer-events:none (look, don't touch) and wrapped in an
                           ErrorBoundary so one bad thumbnail can't take the overview down. *@
                        <button class="ov-card @(entry.Index == State.Index ? "cur" : "")"
                                @key="entry.Index" @onclick="() => Jump(entry.Index)"
                                title="@($"{entry.Index + 1} · {entry.Info.Title}")">
                            <div class="ov-thumb">
                                <div class="ov-stage">
                                    <ErrorBoundary>
                                        <ChildContent>
                                            @* OverviewThumb lets a slide render a lighter version of
                                               itself in the grid — the iframe demos show a poster here
                                               instead of booting a real circuit 41 times. *@
                                            <CascadingValue Name="OverviewThumb" Value="true" IsFixed="true">
                                                <CascadingValue Name="Step" Value="0">
                                                    <DynamicComponent Type="entry.Info.Type" />
                                                </CascadingValue>
                                            </CascadingValue>
                                        </ChildContent>
                                        <ErrorContent></ErrorContent>
                                    </ErrorBoundary>
                                </div>
                            </div>
                            <div class="ov-cap"><span class="ov-num">@(entry.Index + 1)</span><span class="ov-title">@entry.Info.Title</span></div>
                        </button>
                    }
                </div>
            </div>
        }

        @if (State.ShowSettings)
        {
            <div class="settings" @onclick="() => State.CloseSettings()">
                <div class="settings-panel" @onclick:stopPropagation="true">
                    <div class="set-head">Settings <span>Esc to close</span></div>

                    <div class="set-row">
                        <div class="set-label">Theme</div>
                        <div class="set-groups">
                            <div class="set-group">
                                <span class="set-group-label">Dark</span>
                                <div class="set-opts">
                                    @foreach (var (theme, idx) in ThemesFor(dark: true))
                                    {
                                        <button class="set-opt @(State.ThemeIndex == idx ? "active" : "")"
                                                @onclick="() => State.SetTheme(idx)">@theme.AccentName</button>
                                    }
                                </div>
                            </div>
                            <div class="set-group">
                                <span class="set-group-label">Light</span>
                                <div class="set-opts">
                                    @foreach (var (theme, idx) in ThemesFor(dark: false))
                                    {
                                        <button class="set-opt @(State.ThemeIndex == idx ? "active" : "")"
                                                @onclick="() => State.SetTheme(idx)">@theme.AccentName</button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="set-row">
                        <div class="set-label">Default transition</div>
                        <div class="set-opts">
                            @foreach (var tr in SlideTransitions.Selectable)
                            {
                                var trv = tr;
                                <button class="set-opt @(State.DefaultTransition == trv ? "active" : "")"
                                        @onclick="() => State.SetDefaultTransition(trv)">@trv.Label()</button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <footer class="deck-bar">
            <button title="Previous" @onclick="() => State.Prev()">&lsaquo;</button>
            <span class="pos">@(State.Index + 1) / @Slides.Count</span>
            <button title="Next" @onclick="() => State.Next()">&rsaquo;</button>
            <span class="spacer"></span>
            <button title="Overview (o)" @onclick="() => State.ToggleOverview()">overview</button>
            <button title="Reload — watch Server → WebAssembly (r)" @onclick="Reload">&#x27f3;</button>
            <button title="Cycle transition" @onclick="() => State.CycleTransition()">@State.DefaultTransition.Label()</button>
            <button title="Cycle theme (t)" @onclick="() => State.CycleTheme()">@State.Theme.Name</button>
            <button title="Settings (s)" @onclick="() => State.ToggleSettings()">&#9881;</button>
            <button title="Fullscreen (f)" @onclick="ToggleFullscreen">&#x2922;</button>
        </footer>
    </div>
</CascadingValue>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<SlideInfo> Slides { get; set; } = Array.Empty<SlideInfo>();

    /// <summary>1-based slide to open on (from the ?slide= query). Applied once on init.</summary>
    [Parameter] public int? InitialSlide { get; set; }

    /// <summary>Fallback transition for slides that don't set their own.</summary>
    [Parameter] public SlideTransition DefaultTransition { get; set; } = SlideTransition.Fade;

    /// <summary>Persisted theme key + transition (from the URL), applied once on init.</summary>
    [Parameter] public string? InitialTheme { get; set; }
    [Parameter] public string? InitialTransition { get; set; }

    private static IEnumerable<(DeckTheme Theme, int Index)> ThemesFor(bool dark) =>
        DeckThemes.All.Select((theme, i) => (theme, i)).Where(x => x.theme.IsDark == dark);

    // Stable key for persisting the theme (index would be fragile if themes reorder).
    private static string ThemeKey(DeckTheme theme) =>
        $"{(theme.IsDark ? "dark" : "light")}-{theme.AccentName.ToLowerInvariant()}";

    private SlideTransition EffectiveTransition
    {
        get
        {
            if (Slides.Count == 0) return State.DefaultTransition;
            var t = Slides[State.Index].Transition;
            return t == SlideTransition.Inherit ? State.DefaultTransition : t;
        }
    }

    private string TransitionClass => !_hasNavigated
        ? "t-none"                       // first slide on (re)load just appears — no entrance animation
        : EffectiveTransition switch
        {
            SlideTransition.None => "t-none",
            SlideTransition.Slide => "t-slide",
            SlideTransition.SlideVertical => "t-slidev",
            SlideTransition.Scale => "t-scale",
            _ => "t-fade",
        };

    // The exit animation for the outgoing slide — mirrors the incoming transition.
    private string OutgoingClass => EffectiveTransition switch
    {
        SlideTransition.None => "t-none",
        SlideTransition.Slide => "t-slide-out",
        SlideTransition.SlideVertical => "t-slidev-out",
        SlideTransition.Scale => "t-scale-out",
        _ => "t-fade-out",
    };

    private string DirectionClass => State.LastForward ? "dir-fwd" : "dir-back";

    private int ProgressPercent =>
        Slides.Count == 0 ? 0 : (int)Math.Round((State.Index + 1) * 100.0 / Slides.Count);

    private string ComponentName =>
        Slides.Count == 0 ? "" : (Slides[State.Index].Tag ?? Slides[State.Index].Type.Name);

    private DotNetObjectReference<Deck>? _ref;
    private IJSObjectReference? _module;
    private DynamicComponent? _slide;   // the current slide instance, for reading its step count
    private ErrorBoundary? _boundary;   // wraps the slide host; Recover() re-attempts a failed slide
    private bool _overviewScaled;       // whether JS has set the thumbnail scale for the open overview
    private int _shownStep;             // step currently displayed (mirrors State.Step)
    private int _outgoingStep;          // step the exiting slide is frozen at during a transition
    private int _countedIndex = -1;     // last slide index whose step count we read (avoids a per-render read)
    private List<OverviewEntry> _indexed = new();
    private bool _ready;
    private bool _hasNavigated;
    private int _syncedIndex = -1;
    private int _syncedTheme = -1;
    private SlideTransition _syncedTransition = (SlideTransition)(-1);

    // Keep theme/transition out of the URL until they matter: they only appear once
    // they arrived in the URL or the user actually changed them. Plain slide navigation
    // stays clean (/slide/3), not /slide/3?theme=...&transition=....
    private bool _themeInUrl;
    private bool _transitionInUrl;

    // Two-layer transitions: while moving, the slide being left stays mounted as the
    // "outgoing" layer and animates out, so a Slide push slides off the opposite side.
    private int _shownIndex;
    private int? _outgoing;
    private CancellationTokenSource? _outCts;
    private const int TransitionMs = 650;

    private record OverviewEntry(int Index, SlideInfo Info);

    protected override void OnInitialized()
    {
        State.SetCount(Slides.Count);

        // Apply the author default, then any persisted settings from the URL. Done here
        // (before first paint / prerender) so the correct theme renders with no flash.
        State.SetDefaultTransition(DefaultTransition);
        if (!string.IsNullOrEmpty(InitialTheme))
        {
            _themeInUrl = true;
            for (var i = 0; i < DeckThemes.All.Count; i++)
            {
                if (ThemeKey(DeckThemes.All[i]) == InitialTheme) { State.SetTheme(i); break; }
            }
        }
        if (!string.IsNullOrEmpty(InitialTransition) &&
            Enum.TryParse<SlideTransition>(InitialTransition, out var tr))
        {
            _transitionInUrl = true;
            State.SetDefaultTransition(tr);
        }

        State.OnChange += OnStateChanged;
        if (InitialSlide is int slide)
        {
            State.Goto(slide - 1);
        }
        _shownIndex = State.Index;
        _shownStep = State.Step;
    }

    protected override void OnParametersSet()
    {
        State.SetCount(Slides.Count);
        _indexed = Slides.Select((info, i) => new OverviewEntry(i, info)).ToList();
    }

    // DeckState.OnChange is an Action, so this handler returns void. Rather than `async void`
    // (whose exceptions are unobservable), it starts a named task; the one fault we expect is a
    // transition cancelled by a newer navigation, which the catch below swallows.
    private void OnStateChanged() => _ = ReactToStateChangeAsync();

    private async Task ReactToStateChangeAsync()
    {
        try
        {
            // Keep slide + settings (theme, transition) in the URL so a reload restores them
            // with no flash — they're read back at init, even during prerender.
            if (_ready && (State.Index != _syncedIndex
                           || State.ThemeIndex != _syncedTheme
                           || State.DefaultTransition != _syncedTransition))
            {
                // A changed setting is now worth persisting, so let it into the URL.
                if (State.ThemeIndex != _syncedTheme) _themeInUrl = true;
                if (State.DefaultTransition != _syncedTransition) _transitionInUrl = true;

                _syncedIndex = State.Index;
                _syncedTheme = State.ThemeIndex;
                _syncedTransition = State.DefaultTransition;

                // Slide is a route (/slide/N); theme + transition stay in the query, but
                // only once they matter — a null value drops the param entirely.
                var target = Nav.GetUriWithQueryParameters(
                    Nav.ToAbsoluteUri($"slide/{State.Index + 1}").AbsoluteUri,
                    new Dictionary<string, object?>
                    {
                        ["theme"] = _themeInUrl ? ThemeKey(State.Theme) : null,
                        ["transition"] = _transitionInUrl ? State.DefaultTransition.ToString() : null,
                    });
                Nav.NavigateTo(target, replace: true);
            }

            if (State.Index != _shownIndex)
            {
                // Show the slide we're leaving as the outgoing layer while it animates out.
                // With no transition there's nothing to animate, so skip the outgoing layer
                // entirely — otherwise the old slide would sit on top of the new one until the
                // clear-timer fires. EffectiveTransition already reflects the incoming slide.
                if (_ready)
                {
                    _hasNavigated = true;
                    _outgoing = EffectiveTransition == SlideTransition.None ? null : _shownIndex;
                    _outgoingStep = _shownStep;   // freeze the exiting slide at the step it was showing
                }
                _shownIndex = State.Index;
                _shownStep = State.Step;          // new slide starts at step 0

                _outCts?.Cancel();
                _outCts?.Dispose();   // cancel + dispose the previous transition's source before replacing it
                var cts = _outCts = new CancellationTokenSource();
                await InvokeAsync(StateHasChanged);

                if (_outgoing is not null)
                {
                    await Task.Delay(TransitionMs, cts.Token);   // cancelled if a newer navigation starts
                    _outgoing = null;
                    await InvokeAsync(StateHasChanged);
                }
                return;
            }

            _shownStep = State.Step;   // a step change within the current slide
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException)
        {
            // A newer navigation cancelled this transition's delay — expected; the new one owns the UI.
        }
    }

    private void Jump(int index)
    {
        State.Goto(index);
        State.CloseOverview();
    }

    // Re-attempt the current slide after it threw. If it throws again (e.g. it fails on init),
    // the boundary just catches it again — navigating to another slide always recovers.
    private void RecoverSlide() => _boundary?.Recover();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // The slide has rendered, so its instance now exists — report how many build-steps it
        // has. Gate on the slide actually changing so we read once per navigation, not every render.
        if (_countedIndex != State.Index)
        {
            _countedIndex = State.Index;
            State.SetStepCount((_slide?.Instance as ISteppable)?.StepCount ?? 1);
        }

        // When the overview opens, have JS compute the thumbnail scale from the live viewport so the
        // rendered-at-full-size slides shrink faithfully. Reset when it closes so it recomputes next time.
        if (State.ShowOverview)
        {
            if (!_overviewScaled && _module is not null)
            {
                _overviewScaled = true;
                await _module.InvokeVoidAsync("setThumbScale");
                await _module.InvokeVoidAsync("scrollToCurrentThumb");
            }
        }
        else
        {
            _overviewScaled = false;
        }

        if (!firstRender) return;
        _syncedIndex = State.Index;
        _syncedTheme = State.ThemeIndex;
        _syncedTransition = State.DefaultTransition;
        _ready = true;
        _module = await JS.InvokeAsync<IJSObjectReference>(
            "import", "./_content/BlazorDeck/deck.js");
        _ref = DotNetObjectReference.Create(this);
        await _module.InvokeVoidAsync("registerKeys", _ref);
    }

    [JSInvokable]
    public void OnKey(string key)
    {
        switch (key)
        {
            case "ArrowRight" or "ArrowDown" or "PageDown" or " " or "Enter": State.Next(); break;
            case "ArrowLeft" or "ArrowUp" or "PageUp": State.Prev(); break;
            case "Home": State.Goto(0); break;
            case "End": State.Goto(Slides.Count - 1); break;
            case "o": State.ToggleOverview(); break;
            case "s": State.ToggleSettings(); break;
            case "Escape": State.CloseOverview(); State.CloseSettings(); break;
            case "t": State.CycleTheme(); break;
            case "f": _ = ToggleFullscreen(); break;
            case "r": _ = Reload(); break;
        }
    }

    // Reload the current page (position preserved via ?slide=) so the audience can watch
    // Interactive Auto re-decide: Server first, then WebAssembly. Uses location.reload()
    // rather than a scripted navigation, which Chrome would treat as a reason to exit
    // native fullscreen.
    private async Task Reload()
    {
        if (_module is not null)
        {
            await _module.InvokeVoidAsync("reload");
        }
        else
        {
            Nav.NavigateTo(Nav.Uri, forceLoad: true);
        }
    }

    private async Task ToggleFullscreen()
    {
        if (_module is not null)
            await _module.InvokeVoidAsync("toggleFullscreen");
    }

    public async ValueTask DisposeAsync()
    {
        State.OnChange -= OnStateChanged;
        _outCts?.Cancel();
        _outCts?.Dispose();
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("unregisterKeys");
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }
        _ref?.Dispose();
    }
}
