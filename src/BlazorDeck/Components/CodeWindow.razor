@namespace BlazorDeck.Components

@* The reusable highlighted code pane: window chrome (+ optional filename) and a syntax-
   highlighted <pre>. Highlighting runs in C# (see CodeHighlighter) and renders straight into the
   markup, so the code is correct from the first paint — no JS, no flash, correct in prerender.
   Build-steps dim the lines outside the focused region (Focus/Step). *@
<div class="cs-window">
    <div class="cs-chrome">
        <span class="cs-dot"></span><span class="cs-dot"></span><span class="cs-dot"></span>
        @if (!string.IsNullOrWhiteSpace(FileName))
        {
            <span class="cs-file">@FileName</span>
        }
        @if (Optional)
        {
            <span class="cs-opt">optional</span>
        }
        <span class="cs-lang">@Language</span>
    </div>
    @* One .cl block per line; the inner @foreach is kept on one line so no whitespace leaks into
       the pre. <code> is white-space:normal so gaps between the block lines collapse; each .cl is
       white-space:pre so its own indentation is preserved. *@
    <pre class="cs-pre"><code>@for (var i = 0; i < _lines.Count; i++)
    {
        <span class="@(IsDimmed(i) ? "cl dim" : "cl")">@foreach (var t in _lines[i]) {@if (t.Kind is null) {@t.Text} else {<span class="tk-@t.Kind">@t.Text</span>}}@(_lines[i].Count == 0 ? "​" : null)</span>
    }</code></pre>
</div>

@code {
    [Parameter] public string Code { get; set; } = string.Empty;
    [Parameter] public string Language { get; set; } = "csharp";
    [Parameter] public string? FileName { get; set; }
    [Parameter] public bool Optional { get; set; }

    /// <summary>Build-step focus regions, indexed by step. Each entry spotlights a 1-based,
    /// inclusive line range (null = no focus, e.g. the initial step).</summary>
    [Parameter] public IReadOnlyList<(int From, int To)?>? Focus { get; set; }

    /// <summary>Current build-step; picks the active region from <see cref="Focus"/>.</summary>
    [Parameter] public int Step { get; set; }

    private IReadOnlyList<IReadOnlyList<CodeToken>> _lines = Array.Empty<IReadOnlyList<CodeToken>>();
    private string? _tokenized;

    protected override void OnParametersSet()
    {
        if (_tokenized != Code)
        {
            _tokenized = Code;
            _lines = CodeHighlighter.Tokenize(Code);
        }
    }

    private bool IsDimmed(int lineIndex)
    {
        var region = Focus is not null && Step >= 0 && Step < Focus.Count ? Focus[Step] : null;
        if (region is not { } r) return false;
        var n = lineIndex + 1;   // 1-based line number
        return n < r.From || n > r.To;
    }
}
