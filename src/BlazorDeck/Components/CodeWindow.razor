@namespace BlazorDeck.Components
@inject IJSRuntime JS
@implements IAsyncDisposable

@* The reusable highlighted code pane: window chrome (+ optional filename) and a
   syntax-highlighted <pre>. Used by CodeSlide (one file) and by multi-file slides
   like the component anatomy (several stacked windows).
   Shows: lifecycle (#8, OnAfterRenderAsync), JS interop (#18, IJSObjectReference). *@
<div class="cs-window">
    <div class="cs-chrome">
        <span class="cs-dot"></span><span class="cs-dot"></span><span class="cs-dot"></span>
        @if (!string.IsNullOrWhiteSpace(FileName))
        {
            <span class="cs-file">@FileName</span>
        }
        @if (Optional)
        {
            <span class="cs-opt">optional</span>
        }
        <span class="cs-lang">@Language</span>
    </div>
    <pre class="cs-pre"><code @ref="_code">@Code</code></pre>
</div>

@code {
    [Parameter] public string Code { get; set; } = string.Empty;
    [Parameter] public string Language { get; set; } = "csharp";
    [Parameter] public string? FileName { get; set; }
    [Parameter] public bool Optional { get; set; }

    /// <summary>Build-step focus regions, indexed by step. Each entry spotlights a 1-based,
    /// inclusive line range (null = no focus, e.g. the initial step).</summary>
    [Parameter] public IReadOnlyList<(int From, int To)?>? Focus { get; set; }

    /// <summary>Current build-step; picks the active region from <see cref="Focus"/>.</summary>
    [Parameter] public int Step { get; set; }

    private ElementReference _code;
    private IJSObjectReference? _module;
    private string? _highlighted;   // the Code we last tokenised, so step changes don't re-highlight

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        _module ??= await JS.InvokeAsync<IJSObjectReference>(
            "import", "./_content/BlazorDeck/deck.js");

        if (_highlighted != Code)
        {
            _highlighted = Code;
            await _module.InvokeVoidAsync("highlight", _code);
        }

        if (Focus is not null)
        {
            var region = Step >= 0 && Step < Focus.Count ? Focus[Step] : null;
            await _module.InvokeVoidAsync("setFocus", _code, region?.From ?? 0, region?.To ?? 0);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }
    }
}
