@namespace BlazorDeck.Components

@* Layout: frames a live, interactive component inline on a slide (the meta moments).
   The frame itself is the reusable LiveFrame, so a full-slide demo and a demo-beside-code
   (SplitSlide) look identical. *@
<Slide Title="@Title">
    <LiveFrame Label="live component">
        <div class="demo-stage">@ChildContent</div>
    </LiveFrame>
</Slide>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
